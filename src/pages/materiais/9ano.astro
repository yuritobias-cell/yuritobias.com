---
import Layout from '../../layouts/Layout.astro';

const materiais = [
  { n: '01', titulo: 'Apresentação', descricao: 'Introdução ao ano letivo e ao método de trabalho.', arquivo: '01-intro.pdf' },
  { n: '02', titulo: 'Equações', descricao: 'Equações do 1º grau e revisão de álgebra básica.', arquivo: '02-equacoes.pdf' },
  { n: '03', titulo: 'Racionalização', descricao: 'Técnicas de racionalização de denominadores irracionais.', arquivo: '03-racionalizacao.pdf' },
  { n: '04', titulo: 'Radiciação', descricao: 'Operações com raízes e propriedades dos radicais.', arquivo: '04-radiciacao.pdf' },
  { n: '05', titulo: 'Notação Científica', descricao: 'Representação e operações com números em notação científica.', arquivo: '05-notacao-cientifica.pdf' },
  { n: '06', titulo: 'Produtos Notáveis', descricao: 'Quadrado da soma, quadrado da diferença e produto da soma pela diferença.', arquivo: '06-produtos-notaveis.pdf' },
  { n: '07', titulo: 'Equação do 2º Grau — Apostila I', descricao: 'Introdução às equações quadráticas e fórmula de Bhaskara.', arquivo: '07-equacao-2grau-apostila.pdf' },
  { n: '08', titulo: 'Equação do 2º Grau — Apostila II', descricao: 'Exercícios complementares sobre equações do 2º grau.', arquivo: '08-equacoes-2grau-apostila.pdf' },
  { n: '09', titulo: 'Teorema de Tales', descricao: 'Proporcionalidade entre segmentos e o Teorema de Tales.', arquivo: '09-teorema-tales.pdf' },
];
---

<Layout title="9º ano" description="Materiais didáticos de matemática para o 9º ano.">
  <main>
    <nav class="breadcrumb">
      <a href="/materiais">Materiais</a>
      <span>›</span>
      <span>9º ano</span>
    </nav>

    <header>
      <h1>9º ano</h1>
      <p class="subtitle">{materiais.length} materiais disponíveis para download</p>
    </header>

    <ul class="lista">
      {materiais.map((m) => (
        <li class="item">
          <div class="item-info">
            <span class="numero">{m.n}</span>
            <div>
              <p class="titulo">{m.titulo}</p>
              <p class="descricao">{m.descricao}</p>
            </div>
          </div>
          <a href={`/materiais/9ano/${m.arquivo}`} download class="btn">
            Baixar PDF
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
    animation: fade-up 0.5s ease both;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .breadcrumb a {
    color: var(--accent);
    text-decoration: none;
  }

  .breadcrumb a:hover { text-decoration: underline; }

  header { margin-bottom: 2.5rem; }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .subtitle { font-size: 0.9rem; color: var(--muted); font-weight: 300; }

  .lista {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .item:first-child { border-top: 1px solid var(--rule); }

  .item-info {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex: 1;
  }

  .numero {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 300;
    min-width: 1.5rem;
    padding-top: 0.15rem;
  }

  .titulo {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 0.2rem;
  }

  .descricao {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.5;
  }

  .btn {
    flex-shrink: 0;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border: 1px solid var(--accent);
    padding: 0.4rem 0.9rem;
    border-radius: 3px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .btn:hover {
    background: var(--accent);
    color: white;
  }

  @media (max-width: 520px) {
    .item { flex-direction: column; align-items: flex-start; }
  }
</style>