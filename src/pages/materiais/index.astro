---
import Layout from '../../layouts/Layout.astro';
import { seriesAtivas, seriesArquivadas } from '../../utils/materiais';

// Séries arquivadas agrupadas por ano, do mais recente para o mais antigo.
const anosArquivo = [...new Set(seriesArquivadas.map((s) => s.ano))].sort((a, b) => b - a);

const contagem = (n: number) => (n === 1 ? '1 material' : `${n} materiais`);
---

<Layout title="Materiais" description="Materiais didáticos de matemática para 9º ano e Ensino Médio.">
  <main>
    <header>
      <h1>Materiais</h1>
      <p class="subtitle">Apostilas e listas de exercícios organizadas por série.</p>
    </header>

    <div class="grid">
      {seriesAtivas.map((s) => (
        <a href={`/materiais/${s.slug}`} class="card">
          <div class="card-top">
            <span class="serie">{s.tituloLongo}</span>
            <span class="count">{contagem(s.materiais.length + s.provas.length)}</span>
          </div>
          <p class="descricao">{s.descricao}</p>
          <span class="cta">Ver materiais →</span>
        </a>
      ))}
    </div>

    {anosArquivo.length > 0 && (
      <section class="arquivo">
        <h2>Arquivo</h2>
        <p class="subtitle">Materiais de anos letivos encerrados.</p>
        {anosArquivo.map((ano) => (
          <div class="arquivo-ano">
            <h3>{ano}</h3>
            <ul>
              {seriesArquivadas.filter((s) => s.ano === ano).map((s) => (
                <li>
                  <a href={`/materiais/arquivo/${s.ano}/${s.slug}`}>{s.tituloLongo}</a>
                  <span class="count">{contagem(s.materiais.length + s.provas.length)}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    )}
  </main>
</Layout>

<style>
  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    animation: fade-up 0.5s ease both;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  header { margin-bottom: 3rem; }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .subtitle { font-size: 0.95rem; color: var(--muted); font-weight: 300; }

  .grid { display: grid; gap: 1rem; }

  .card {
    display: block;
    text-decoration: none;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--rule);
    border-radius: 4px;
    background: white;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .card:hover {
    border-color: var(--accent);
    transform: translateX(4px);
  }

  .card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .serie {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--ink);
  }

  .count { font-size: 0.8rem; color: var(--muted); font-weight: 300; }

  .descricao {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .cta {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .arquivo { margin-top: 4rem; padding-top: 2.5rem; border-top: 1px solid var(--rule); }

  .arquivo h2 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 0.3rem;
  }

  .arquivo-ano { margin-top: 1.75rem; }

  .arquivo-ano h3 {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }

  .arquivo-ano ul { list-style: none; display: flex; flex-direction: column; }

  .arquivo-ano li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .arquivo-ano li:first-child { border-top: 1px solid var(--rule); }

  .arquivo-ano a {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
  }

  .arquivo-ano a:hover { text-decoration: underline; }
</style>
