---
/* Séries de anos letivos encerrados (arquivada: true no manifesto).
   Só gera páginas quando existe série arquivada — até lá, a rota fica dormente. */
import Layout from '../../../../layouts/Layout.astro';
import SecoesMateriais from '../../../../components/SecoesMateriais.astro';
import { seriesArquivadas, type Serie } from '../../../../utils/materiais';

export function getStaticPaths() {
  return seriesArquivadas.map((serie) => ({
    params: { ano: String(serie.ano), serie: serie.slug },
    props: { serie },
  }));
}

interface Props {
  serie: Serie;
}

const { serie } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Materiais', item: new URL('/materiais/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: `${serie.titulo} · ${serie.ano}` },
  ],
};
---

<Layout title={`${serie.titulo} · ${serie.ano}`} description={`${serie.descricaoMeta} Arquivo do ano letivo de ${serie.ano}.`} schema={schema}>
  <main>
    <nav class="breadcrumb">
      <a href="/materiais">Materiais</a>
      <span>›</span>
      <span>Arquivo</span>
      <span>›</span>
      <span>{serie.titulo} · {serie.ano}</span>
    </nav>

    <header>
      <h1>{serie.titulo} <span class="ano">· {serie.ano}</span></h1>
      <p class="aviso">Arquivo do ano letivo de {serie.ano} — este conteúdo não recebe mais atualizações.</p>
    </header>

    <SecoesMateriais serie={serie} />
  </main>
</Layout>

<style>
  main { max-width: 720px; margin: 0 auto; padding: 3rem 1.5rem 5rem; animation: fade-up 0.5s ease both; }
  @keyframes fade-up { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--muted); margin-bottom: 2rem; }
  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  header { margin-bottom: 2.5rem; }
  h1 { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.4rem; }
  .ano { color: var(--muted); font-weight: 400; }
  .aviso { font-size: 0.9rem; color: var(--muted); font-weight: 300; }
</style>
