---
import Layout from '../../layouts/Layout.astro';

const materiais = [
  { n: '01', titulo: 'Apresentação', descricao: 'Introdução ao Ensino Médio e ao método de trabalho.', arquivo: '01-intro.pdf' },
  { n: '02', titulo: 'Conjuntos', descricao: 'Teoria dos conjuntos: representação e operações.', arquivo: '02-conjuntos.pdf' },
  { n: '03', titulo: 'Conjuntos — Diagrama de Venn', descricao: 'Representação visual de conjuntos e suas operações.', arquivo: '03-conjuntos-venn.pdf' },
  { n: '04', titulo: 'Fração Geratriz', descricao: 'Conversão de dízimas periódicas em frações.', arquivo: '04-fracao-geratriz.pdf' },
  { n: '05', titulo: 'Operações com Reais', descricao: 'Operações no conjunto dos números reais.', arquivo: '05-operacoes-reais.pdf' },
  { n: '06', titulo: 'Fechamento de Capítulo', descricao: 'Revisão e exercícios integrados da unidade.', arquivo: '06-fechamento-capitulo.pdf' },
  { n: '07', titulo: 'Áreas — Apostila', descricao: 'Cálculo de áreas de figuras planas.', arquivo: '07-areas-apostila.pdf' },
  { n: '08', titulo: 'Plano Cartesiano — Apostila', descricao: 'Coordenadas, distâncias e ponto médio.', arquivo: '08-plano-cartesiano.pdf' },
  { n: '09', titulo: 'Produto Cartesiano', descricao: 'Conceito e aplicações do produto cartesiano.', arquivo: '09-produto-cartesiano.pdf' },
  { n: '10', titulo: 'Classificação de Funções', descricao: 'Tipos de funções e suas características principais.', arquivo: '10-classificacao-funcoes.pdf' },
];
---

<Layout title="1º ano — Ensino Médio" description="Materiais didáticos de matemática para o 1º ano do Ensino Médio.">
  <main>
    <nav class="breadcrumb">
      <a href="/materiais">Materiais</a>
      <span>›</span>
      <span>1º ano — Ensino Médio</span>
    </nav>

    <header>
      <h1>1º ano — Ensino Médio</h1>
      <p class="subtitle">{materiais.length} materiais disponíveis para download</p>
    </header>

    <ul class="lista">
      {materiais.map((m) => (
        <li class="item">
          <div class="item-info">
            <span class="numero">{m.n}</span>
            <div>
              <p class="titulo">{m.titulo}</p>
              <p class="descricao">{m.descricao}</p>
            </div>
          </div>
          <a href={`/materiais/1em/${m.arquivo}`} download class="btn">
            Baixar PDF
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
    animation: fade-up 0.5s ease both;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
    margin-bottom: 2rem;
  }

  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  header { margin-bottom: 2.5rem; }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }

  .subtitle { font-size: 0.9rem; color: var(--muted); font-weight: 300; }

  .lista { list-style: none; display: flex; flex-direction: column; }

  .item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .item:first-child { border-top: 1px solid var(--rule); }

  .item-info { display: flex; align-items: flex-start; gap: 1rem; flex: 1; }

  .numero { font-size: 0.75rem; color: var(--muted); font-weight: 300; min-width: 1.5rem; padding-top: 0.15rem; }

  .titulo { font-size: 0.95rem; font-weight: 500; color: var(--ink); margin-bottom: 0.2rem; }

  .descricao { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }

  .btn {
    flex-shrink: 0;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    border: 1px solid var(--accent);
    padding: 0.4rem 0.9rem;
    border-radius: 3px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .btn:hover { background: var(--accent); color: white; }

  @media (max-width: 520px) {
    .item { flex-direction: column; align-items: flex-start; }
  }
</style>