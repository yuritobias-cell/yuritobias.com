---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import materiais9ano from '../../data/9ano.json';
import provas9ano from '../../data/provas-9ano.json';
import materiais1em from '../../data/1em.json';
import provas1em from '../../data/provas-1em.json';
import materiais2em from '../../data/2em.json';
import provas2em from '../../data/provas-2em.json';

export function getStaticPaths() {
  // Falha o build se algum JSON referenciar um PDF que não existe em public/materiais/<serie>/
  // (definida aqui dentro porque o Astro executa getStaticPaths em escopo isolado)
  function validarArquivos(serie, ...listas) {
    const dir = path.join(process.cwd(), 'public', 'materiais', serie);
    const emDisco = new Set(fs.readdirSync(dir));
    const faltando = listas.flat()
      .map((m) => m.arquivo)
      .filter((a) => a && !emDisco.has(a));
    if (faltando.length > 0) {
      throw new Error(
        `[materiais/${serie}] PDF referenciado no JSON mas ausente em public/materiais/${serie}/: ${faltando.join(', ')}`
      );
    }
  }

  validarArquivos('9ano', materiais9ano, provas9ano);
  validarArquivos('1em', materiais1em, provas1em);
  validarArquivos('2em', materiais2em, provas2em);

  return [
    {
      params: { serie: '9ano' },
      props: {
        titulo: '9º ano',
        descricaoMeta: 'Materiais didáticos de matemática para o 9º ano do Ensino Fundamental.',
        materiais: materiais9ano,
        provas: provas9ano,
      },
    },
    {
      params: { serie: '1em' },
      props: {
        titulo: '1º EM',
        descricaoMeta: 'Materiais didáticos de matemática para o 1º ano do Ensino Médio.',
        materiais: materiais1em,
        provas: provas1em,
      },
    },
    {
      params: { serie: '2em' },
      props: {
        titulo: '2º EM',
        descricaoMeta: 'Materiais didáticos de matemática para o 2º ano do Ensino Médio.',
        materiais: materiais2em,
        provas: provas2em,
      },
    },
  ];
}

const { serie } = Astro.params;
const { titulo, descricaoMeta, materiais, provas } = Astro.props;

const paracasa = materiais.filter((m) => !m.video);
const revisoes = materiais.filter((m) => m.video);

function formatarData(iso) {
  const partes = iso.split('-');
  if (partes.length !== 3) return iso;
  return `${partes[2]}/${partes[1]}`;
}
---

<Layout title={titulo} description={descricaoMeta}>
  <main>
    <nav class="breadcrumb">
      <a href="/materiais">Materiais</a>
      <span>›</span>
      <span>{titulo}</span>
    </nav>

    <header>
      <h1>{titulo}</h1>
    </header>

    <!-- Seção: Para Casa -->
    <section class="secao">
      <h2 class="secao-titulo">Para Casa</h2>
      <p class="subtitle">{paracasa.length} materiais disponíveis</p>
      <ul class="lista">
        {paracasa.map((m) => (
          <li class="item">
            <div class="item-info">
              <span class="numero">{m.n}</span>
              <div class="item-texto">
                <p class="titulo">{m.titulo}</p>
                <p class="descricao">{m.descricao}</p>
                {m.apostila && (
                  <p class="apostila-ref">
                    <span class="apostila-tag">Apostila</span>{m.apostila.ordem}
                  </p>
                )}
              </div>
            </div>
            <div class="acoes">
              {m.arquivo && (
                <a href={`/materiais/${serie}/${m.arquivo}`} download class="btn">
                  Baixar PDF
                </a>
              )}
              {m.apostila && m.apostila.data && (
                <span class="badge-data" data-date={m.apostila.data}>{formatarData(m.apostila.data)}</span>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- Seção: Revisão -->
    <section class="secao">
      <h2 class="secao-titulo">Revisão</h2>
      <p class="subtitle">{revisoes.length} listas disponíveis</p>
      <ul class="lista">
        {revisoes.map((m) => (
          <li class="item">
            <div class="item-info">
              <span class="numero">{m.n}</span>
              <div class="item-texto">
                <p class="titulo">{m.titulo}</p>
                <p class="descricao">{m.descricao}</p>
                {m.video && m.video.topicos.length > 0 && (
                  <ul class="topicos">
                    {m.video.topicos.map((t) => (
                      <li>{t}</li>
                    ))}
                  </ul>
                )}
              </div>
            </div>
            <div class="acoes">
              <a href={`/materiais/${serie}/${m.arquivo}`} download class="btn">
                Baixar PDF
              </a>
              {m.video.url && (
                <a href={m.video.url} target="_blank" rel="noopener noreferrer" class="btn btn-video">
                  ▶ Vídeo
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <!-- Seção: Provas -->
    <section class="secao">
      <h2 class="secao-titulo">Somativas</h2>
      <p class="subtitle">{provas.length} provas disponíveis</p>
      <ul class="lista">
        {provas.map((p) => (
          <li class="item">
            <div class="item-info">
              <span class="numero">{p.n}</span>
              <div>
                <p class="titulo">{p.titulo}</p>
                <p class="descricao">{p.descricao}</p>
              </div>
            </div>
            <a href={`/materiais/${serie}/${p.arquivo}`} download class="btn">
              Baixar PDF
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
</Layout>

<script>
  // Destaca tarefas com data de entrega hoje ou no futuro
  const hoje = new Date().toLocaleDateString('sv-SE'); // YYYY-MM-DD no fuso local
  document.querySelectorAll<HTMLElement>('.badge-data[data-date]').forEach((el) => {
    const data = el.dataset.date ?? '';
    el.classList.add(data >= hoje ? 'futura' : 'vencida');
  });
</script>

<style>
  main { max-width: 720px; margin: 0 auto; padding: 3rem 1.5rem 5rem; animation: fade-up 0.5s ease both; }
  @keyframes fade-up { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--muted); margin-bottom: 2rem; }
  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  header { margin-bottom: 2.5rem; }
  h1 { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.4rem; }
  .subtitle { font-size: 0.9rem; color: var(--muted); font-weight: 300; }
  .lista { list-style: none; display: flex; flex-direction: column; }
  .item { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.25rem 0; border-bottom: 1px solid var(--rule); }
  .item:first-child { border-top: 1px solid var(--rule); }
  .item-info { display: flex; align-items: flex-start; gap: 1rem; flex: 1; }
  .item-texto { display: flex; flex-direction: column; gap: 0.2rem; }
  .numero { font-size: 0.75rem; color: var(--muted); font-weight: 300; min-width: 1.5rem; padding-top: 0.15rem; }
  .titulo { font-size: 0.95rem; font-weight: 500; color: var(--ink); margin-bottom: 0.2rem; }
  .descricao { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }
  .apostila-ref { font-size: 0.85rem; color: var(--ink); line-height: 1.5; margin-top: 0.4rem; }
  .apostila-tag { display: inline-block; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent); border: 1px solid var(--accent); border-radius: 3px; padding: 0.05rem 0.4rem; margin-right: 0.5rem; }
  .badge-data { font-size: 0.78rem; font-weight: 500; color: var(--muted); white-space: nowrap; letter-spacing: 0.02em; }
  .badge-data.futura { color: var(--accent); font-weight: 600; border: 1px solid var(--accent); border-radius: 3px; padding: 0.2rem 0.5rem; }
  .badge-data.futura::before { content: 'para '; }
  .topicos { list-style: none; margin-top: 0.5rem; display: flex; flex-direction: column; gap: 0.2rem; }
  .topicos li { font-size: 0.8rem; color: var(--muted); padding-left: 0.75rem; position: relative; }
  .topicos li::before { content: '–'; position: absolute; left: 0; }
  .acoes { display: flex; flex-direction: column; gap: 0.4rem; flex-shrink: 0; align-items: flex-end; }
  .btn { flex-shrink: 0; text-decoration: none; font-size: 0.8rem; font-weight: 500; color: var(--accent); letter-spacing: 0.03em; text-transform: uppercase; border: 1px solid var(--accent); padding: 0.4rem 0.9rem; border-radius: 3px; transition: background 0.2s ease, color 0.2s ease; }
  .btn:hover { background: var(--accent); color: white; }
  .btn-video { color: var(--muted); border-color: var(--rule); }
  .btn-video:hover { background: var(--ink); border-color: var(--ink); color: white; }
  .secao { margin-bottom: 3.5rem; }
  .secao-titulo { font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; margin-bottom: 0.3rem; }
  @media (max-width: 520px) { .item { flex-direction: column; align-items: flex-start; } .acoes { flex-direction: row; } }
</style>
