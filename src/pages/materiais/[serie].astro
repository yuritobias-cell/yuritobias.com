---
import Layout from '../../layouts/Layout.astro';
import SecoesMateriais from '../../components/SecoesMateriais.astro';
import { seriesAtivas, type Serie } from '../../utils/materiais';

export function getStaticPaths() {
  return seriesAtivas.map((serie) => ({
    params: { serie: serie.slug },
    props: { serie },
  }));
}

interface Props {
  serie: Serie;
}

const { serie } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Materiais', item: new URL('/materiais/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: serie.titulo },
  ],
};
---

<Layout title={serie.titulo} description={serie.descricaoMeta} schema={schema}>
  <main>
    <nav class="breadcrumb">
      <a href="/materiais">Materiais</a>
      <span>›</span>
      <span>{serie.titulo}</span>
    </nav>

    <header>
      <h1>{serie.titulo}</h1>
    </header>

    <SecoesMateriais serie={serie} />
  </main>
</Layout>

<style>
  main { max-width: 720px; margin: 0 auto; padding: 3rem 1.5rem 5rem; animation: fade-up 0.5s ease both; }
  @keyframes fade-up { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .breadcrumb { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; color: var(--muted); margin-bottom: 2rem; }
  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  header { margin-bottom: 2.5rem; }
  h1 { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.4rem; }
</style>
