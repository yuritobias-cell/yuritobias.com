---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Testador de Senhas"
  description="Simule um ataque de força bruta e veja quanto tempo levaria para quebrar uma senha — análise combinatória aplicada à segurança digital."
>

  <!-- IBM Plex Mono + pesos 600/700 do Plex Sans carregados só nesta página.
       Playfair Display + IBM Plex Sans (300–500) já vêm do Layout. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@600;700&display=swap" rel="stylesheet" />

  <div class="tsr-root">
    <div class="wrap">

      <header class="masthead">
        <p class="eyebrow"><a href="/ferramentas">Ferramentas</a> · Análise combinatória</p>
        <h1>Testador de senhas</h1>
        <p class="lede">Um simulador de força bruta: escolha uma senha curta, veja quantas combinações existem e quanto tempo cada cenário de ataque levaria para esgotá-las — e por que cada caractere a mais muda tudo. Nenhuma senha sai da página.</p>
      </header>

      <!-- ================= SENHA E CONJUNTO ================= -->
      <section class="card">
        <div class="grid2">
          <div class="campo">
            <label class="mini" for="pwd-in">Senha (2 a 4 caracteres)</label>
            <div class="senha-row">
              <input type="text" id="pwd-in" maxlength="4" placeholder="ex: 7392" spellcheck="false" autocomplete="off">
              <button class="btn sec" id="gen-btn">↻ gerar</button>
            </div>
          </div>
          <div class="campo">
            <label class="mini" for="cs-sel">Conjunto de caracteres</label>
            <select id="cs-sel">
              <option value="digits">Apenas dígitos · 10 símbolos</option>
              <option value="lower">Dígitos + letras minúsculas · 36 símbolos</option>
              <option value="mixed">Dígitos + minúsculas + maiúsculas · 62 símbolos</option>
            </select>
          </div>
        </div>

        <div class="formula">
          <span class="formula-eq">combinações possíveis = |conjunto|<sup>comprimento</sup></span>
          <div class="formula-linha" id="math-line">Digite ou gere uma senha acima</div>
          <div class="formula-nota" id="math-note"></div>
        </div>
      </section>

      <!-- ================= PROJEÇÃO ================= -->
      <section class="proj">
        <div class="proj-titulo">Projeção · tempo para esgotar todas as combinações (pior caso)</div>
        <div class="proj-row proj-head">
          <span>Cenário de ataque</span><span>Velocidade</span><span>Tempo estimado</span>
        </div>
        <div class="proj-row">
          <span>Ataque online <span class="obs">(servidor limita após erros)</span></span>
          <span class="mono obs">10 /s</span>
          <span id="pt-online" class="mono destaque">—</span>
        </div>
        <div class="proj-row">
          <span>CPU moderna <span class="obs">(ataque offline)</span></span>
          <span class="mono obs">10⁶ /s</span>
          <span id="pt-cpu" class="mono destaque">—</span>
        </div>
        <div class="proj-row">
          <span>GPU dedicada <span class="obs">(ex: RTX 4090)</span></span>
          <span class="mono obs">10¹⁰ /s</span>
          <span id="pt-gpu" class="mono destaque">—</span>
        </div>
      </section>

      <!-- ================= SIMULAÇÃO ================= -->
      <section class="card">
        <div class="config-grid">
          <div class="campo campo-veloc">
            <label class="mini" id="speed-lbl" for="speed-sl">Velocidade da simulação: <strong>50 tentativas/s</strong></label>
            <input type="range" id="speed-sl" min="0" max="4" value="1" step="1">
            <div class="ticks"><span>5/s</span><span>50/s</span><span>500/s</span><span>5.000/s</span><span>50.000/s</span></div>
            <p class="nota" id="speed-hint">Bom para ver o processo em ação</p>
          </div>
          <div class="campo">
            <label class="mini" for="cap-input">Limite de tempo da simulação</label>
            <div class="cap-row">
              <button class="btn sec mini-btn" data-cap-delta="-30" aria-label="Diminuir 30 segundos">−</button>
              <input type="number" id="cap-input" min="10" max="600" value="30" step="10">
              <span class="obs">segundos</span>
              <button class="btn sec mini-btn" data-cap-delta="30" aria-label="Aumentar 30 segundos">+</button>
            </div>
            <div class="cap-row">
              <button class="btn sec mini-btn" data-cap="30">30s</button>
              <button class="btn sec mini-btn" data-cap="60">1 min</button>
              <button class="btn sec mini-btn" data-cap="120">2 min</button>
              <button class="btn sec mini-btn" data-cap="300">5 min</button>
            </div>
            <p class="nota" id="cap-note">—</p>
          </div>
        </div>

        <div class="acoes">
          <button class="btn" id="start-btn">▶ Iniciar</button>
          <button class="btn sec" id="stop-btn" disabled>◼ Parar</button>
          <button class="btn sec" id="reset-btn">↺ Reiniciar</button>
          <span class="cap-warn" id="cap-warn" hidden>⚠ A senha está além do limite — será exibida ao final do tempo</span>
        </div>
        <div class="aviso" id="err-box" hidden></div>
      </section>

      <!-- ================= PROGRESSO ================= -->
      <section class="card" id="prog-sec" hidden>
        <div class="secao-titulo">Tentativa atual</div>
        <div class="cur-att" id="cur-att">----</div>
        <div class="prog-bar-wrap"><div class="prog-bar-fill" id="prog-bar"></div></div>
        <div class="timer-head">
          <span>Tempo restante</span>
          <span class="mono" id="timer-display">—</span>
        </div>
        <div class="timer-bar-wrap"><div class="timer-bar-fill" id="timer-bar"></div></div>
        <div class="stat-grid">
          <div class="stat-card"><p class="stat-lbl">Tentativas</p><p class="stat-val" id="att-count">0</p></div>
          <div class="stat-card"><p class="stat-lbl">Total possível</p><p class="stat-val" id="att-total">—</p></div>
          <div class="stat-card"><p class="stat-lbl">Velocidade real</p><p class="stat-val" id="speed-real">0/s</p></div>
          <div class="stat-card"><p class="stat-lbl">Progresso</p><p class="stat-val" id="prog-pct">0%</p></div>
        </div>
      </section>

      <!-- ================= RESULTADO ================= -->
      <section class="result" id="result-sec" hidden>
        <p class="result-title" id="result-title">Senha encontrada!</p>
        <p class="result-txt" id="result-txt"></p>
      </section>

      <!-- ================= HISTÓRICO ================= -->
      <section id="hist-sec" hidden>
        <div class="secao-titulo">Histórico de execuções</div>
        <div class="hist">
          <div class="hist-row hist-head"><span>Senha</span><span>Conjunto</span><span>Tentativas</span><span>Tempo</span><span>Limite</span><span>Veloc.</span></div>
          <div id="hist-body"></div>
        </div>
      </section>

    </div>
  </div>

</Layout>

<style is:global>
  /* ============================================================
     Ferramenta: Testador de senhas
     CSS escopado sob .tsr-root para não vazar para o resto do site.
     Variáveis no próprio .tsr-root, na paleta do site.
     ============================================================ */

  .tsr-root{
    --papel:#F8F6F1; --tinta:#1B4F4F; --tinta-2:#2f6b6b;
    --traco:#d8d2c4; --neutro:#6b6459;
    --ocre:#936614;  --ocre-bg:#f7efdd;   /* alertas, tempo médio     */
    --terra:#A8442B; --terra-bg:#f9e9e4;  /* erros, tempo curto       */
    --verde:#0f6e56; --verde-bg:#e3f1ec;  /* sucesso, tempo geológico */
    --font-mono:'IBM Plex Mono',ui-monospace,monospace;

    background:var(--papel); color:var(--tinta);
    font-family:'IBM Plex Sans',system-ui,sans-serif; line-height:1.5;
    padding:2rem 1.2rem 4rem;
  }
  .tsr-root [hidden]{ display:none !important; }
  .tsr-root .wrap{ max-width:760px; margin:0 auto; }

  .tsr-root .masthead{ margin-bottom:1.4rem; }
  .tsr-root .masthead .eyebrow{
    font-family:var(--font-mono); font-size:0.75rem;
    letter-spacing:0.12em; text-transform:uppercase; color:var(--neutro); margin:0 0 .6rem;
  }
  .tsr-root .masthead .eyebrow a{ color:inherit; text-decoration:none; }
  .tsr-root .masthead .eyebrow a:hover{ color:var(--tinta); }
  .tsr-root .masthead h1{ font-family:'Playfair Display',Georgia,serif; font-weight:700;
    font-size:clamp(1.6rem,4vw,2.2rem); margin:0 0 .2rem; }
  .tsr-root .masthead .lede{ color:var(--neutro); margin:0; font-size:.95rem; max-width:62ch; }

  /* ---------- cartões e campos ---------- */
  .tsr-root .card{ background:#fff; border:1px solid var(--traco); border-radius:12px;
    padding:1.1rem 1.2rem; margin-bottom:1rem; }
  .tsr-root .campo{ display:flex; flex-direction:column; gap:.35rem; }
  .tsr-root label.mini{ display:block; font-weight:600; font-size:.74rem; text-transform:uppercase;
    letter-spacing:.06em; margin:0; color:var(--tinta-2); }
  .tsr-root .grid2{ display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
  .tsr-root input[type=text], .tsr-root select{
    width:100%; background:#fff; border:1px solid var(--traco); border-radius:9px;
    padding:.55rem .8rem; font:inherit; color:var(--tinta); }
  .tsr-root input:focus, .tsr-root select:focus{ outline:2px solid var(--tinta); outline-offset:1px; }
  .tsr-root .senha-row{ display:flex; gap:.5rem; }
  .tsr-root #pwd-in{ flex:1; font-family:var(--font-mono); font-size:1.1rem; letter-spacing:.15em; }
  .tsr-root input[type=number]{ width:4.5rem; background:#fff; border:1px solid var(--traco);
    border-radius:8px; padding:.4rem; font:inherit; font-family:var(--font-mono); text-align:center; }
  .tsr-root input[type=range]{ width:100%; cursor:pointer; accent-color:var(--tinta); }

  .tsr-root .btn{ background:var(--tinta); color:var(--papel); border:0; border-radius:8px;
    padding:.5rem .85rem; font:inherit; font-weight:600; cursor:pointer; }
  .tsr-root .btn:hover{ background:var(--tinta-2); }
  .tsr-root .btn:disabled{ opacity:.4; cursor:not-allowed; }
  .tsr-root .btn.sec{ background:#fff; color:var(--tinta); border:1px solid var(--traco); }
  .tsr-root .btn.sec:hover{ background:var(--papel); }
  .tsr-root .btn.sec:disabled:hover{ background:#fff; }
  .tsr-root .btn.mini-btn{ padding:.25rem .6rem; font-size:.78rem; font-weight:500; }

  .tsr-root .mono{ font-family:var(--font-mono); }
  .tsr-root .obs{ font-size:.78rem; color:var(--neutro); }
  .tsr-root .nota{ font-size:.78rem; color:var(--neutro); margin:.2rem 0 0; line-height:1.5; }
  .tsr-root .destaque{ font-weight:500; font-size:.85rem; }
  .tsr-root .secao-titulo{ font-weight:700; font-size:.8rem; text-transform:uppercase;
    letter-spacing:.08em; color:var(--tinta-2); margin:0 0 .5rem; }

  /* ---------- fórmula ---------- */
  .tsr-root .formula{ margin-top:1rem; padding-top:.9rem; border-top:1px solid var(--traco);
    font-family:var(--font-mono); }
  .tsr-root .formula-eq{ font-size:.75rem; color:var(--neutro); }
  .tsr-root .formula-linha{ font-size:1.05rem; font-weight:500; margin-top:.25rem; }
  .tsr-root .formula-nota{ font-size:.8rem; color:var(--neutro); margin-top:.15rem; }
  .tsr-root .formula-nota.invalida{ color:var(--terra); }

  /* ---------- tabela de projeção ---------- */
  .tsr-root .proj{ background:#fff; border:1px solid var(--traco); border-radius:12px;
    overflow:hidden; margin-bottom:1rem; }
  .tsr-root .proj-titulo{ background:var(--papel); padding:.5rem .9rem; font-size:.72rem;
    color:var(--tinta-2); font-weight:700; text-transform:uppercase; letter-spacing:.06em; }
  .tsr-root .proj-row{ display:grid; grid-template-columns:1fr 110px 170px; gap:.8rem;
    align-items:center; padding:.55rem .9rem; border-top:1px solid var(--traco); font-size:.88rem; }
  .tsr-root .proj-head{ font-size:.7rem; color:var(--neutro); font-weight:600;
    background:var(--papel); text-transform:uppercase; letter-spacing:.05em; padding:.4rem .9rem; }

  /* ---------- configuração da simulação ---------- */
  .tsr-root .config-grid{ display:flex; gap:1.5rem 2rem; flex-wrap:wrap; }
  .tsr-root .campo-veloc{ flex:1 1 260px; }
  .tsr-root .ticks{ display:flex; justify-content:space-between; font-size:.7rem;
    color:var(--neutro); margin-top:.2rem; }
  .tsr-root .cap-row{ display:flex; align-items:center; gap:.4rem; flex-wrap:wrap; }
  .tsr-root .acoes{ display:flex; gap:.6rem; align-items:center; flex-wrap:wrap;
    margin-top:1rem; padding-top:.9rem; border-top:1px solid var(--traco); }
  .tsr-root .cap-warn{ font-size:.8rem; color:var(--ocre); font-weight:500; }
  .tsr-root .aviso{ margin-top:.7rem; color:var(--terra); font-weight:600; font-size:.9rem; }

  /* ---------- progresso ---------- */
  .tsr-root .cur-att{ font-family:var(--font-mono); font-size:2.4rem; font-weight:500;
    letter-spacing:.2em; line-height:1.1; margin:.2rem 0 .8rem; }
  .tsr-root .prog-bar-wrap{ background:var(--papel); border-radius:4px; height:6px;
    overflow:hidden; margin-bottom:1rem; }
  .tsr-root .prog-bar-fill{ background:var(--tinta); height:100%; width:0%; transition:width .08s; }
  .tsr-root .timer-head{ display:flex; justify-content:space-between; align-items:center;
    font-size:.75rem; color:var(--neutro); margin-bottom:.3rem; }
  .tsr-root .timer-bar-wrap{ background:var(--papel); border-radius:4px; height:4px; overflow:hidden; }
  .tsr-root .timer-bar-fill{ background:var(--verde); height:100%; width:0%; transition:width .5s linear; }
  .tsr-root .stat-grid{ display:grid; grid-template-columns:repeat(4,1fr); gap:.6rem; margin-top:1rem; }
  .tsr-root .stat-card{ background:var(--papel); border-radius:8px; padding:.6rem .8rem; }
  .tsr-root .stat-lbl{ font-size:.72rem; color:var(--neutro); margin:0 0 .15rem; }
  .tsr-root .stat-val{ font-size:1rem; font-weight:600; margin:0; font-family:var(--font-mono); }

  /* ---------- resultado ---------- */
  .tsr-root .result{ border-radius:12px; border:1.4px solid; padding:.9rem 1.1rem; margin-bottom:1rem; }
  .tsr-root .result.found{ background:var(--verde-bg); border-color:var(--verde); color:var(--verde); }
  .tsr-root .result.capped{ background:var(--ocre-bg); border-color:var(--ocre); color:var(--ocre); }
  .tsr-root .result-title{ font-weight:600; margin:0 0 .2rem; }
  .tsr-root .result-txt{ font-family:var(--font-mono); font-size:.82rem; margin:0;
    line-height:1.7; white-space:pre-line; }

  /* ---------- histórico ---------- */
  .tsr-root .hist{ background:#fff; border:1px solid var(--traco); border-radius:12px; overflow:hidden; }
  .tsr-root .hist-row{ display:grid; grid-template-columns:70px 1fr 100px 60px 60px 80px;
    gap:.5rem; align-items:center; padding:.5rem .9rem; font-size:.82rem; }
  .tsr-root .hist-row + .hist-row{ border-top:1px solid var(--traco); }
  .tsr-root .hist-head{ font-size:.7rem; color:var(--neutro); font-weight:600;
    background:var(--papel); text-transform:uppercase; letter-spacing:.05em; }
  .tsr-root .hist-row.recente{ background:var(--papel); }

  @media (max-width:560px){
    .tsr-root .grid2{ grid-template-columns:1fr; }
    .tsr-root .stat-grid{ grid-template-columns:repeat(2,1fr); }
    .tsr-root .proj-row{ grid-template-columns:1fr 100px; }
    .tsr-root .proj-row span:nth-child(2){ display:none; }
    .tsr-root .hist-row{ grid-template-columns:60px 1fr 90px 60px 60px; }
    .tsr-root .hist-row span:last-child{ display:none; }
    .tsr-root .cur-att{ font-size:1.6rem; }
  }
</style>

<script>
  // @ts-nocheck — JS vanilla da ferramenta; sem tipagem TS
  const CS={digits:"0123456789",lower:"0123456789abcdefghijklmnopqrstuvwxyz",mixed:"0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"};
  const CS_NAMES={digits:"dígitos (10)",lower:"díg.+min. (36)",mixed:"díg.+min.+mai. (62)"};
  const SPEEDS=[5,50,500,5000,50000];
  const SPEED_HINTS=["Ideal para acompanhar cada tentativa com calma","Bom para ver o processo em ação","Equilíbrio entre visibilidade e agilidade","Senhas longas ficam visíveis mais rápido","Para demonstrar escala em grandes conjuntos"];
  const SCENARIOS=[{id:"online",speed:10},{id:"cpu",speed:1e6},{id:"gpu",speed:1e10}];
  const $=id=>document.getElementById(id);
  let running=false,rafId=null,currentIdx=0,targetIdx=0,total=0,chars="",pwdLen=0,simSpeed=0,startTime=0,simCapMs=30000;
  const execucoes=[];

  function idx2str(idx,c,len){let r="",n=idx;for(let i=0;i<len;i++){r=c[n%c.length]+r;n=Math.floor(n/c.length);}return r;}
  function str2idx(s,c){let idx=0;for(let i=0;i<s.length;i++){const p=c.indexOf(s[i]);if(p<0)return -1;idx=idx*c.length+p;}return idx;}
  function fmtTime(s){
    if(s<0.001)return"instantâneo";if(s<1)return"< 1 segundo";
    if(s<60){const v=Math.ceil(s);return v+(v===1?" segundo":" segundos");}
    if(s<3600){const v=Math.ceil(s/60);return"~"+v+" minuto"+(v===1?"":"s");}
    if(s<86400)return"~"+(s/3600).toFixed(1)+" horas";
    if(s<86400*30)return"~"+(s/86400).toFixed(1)+" dias";
    if(s<86400*365)return"~"+Math.round(s/(86400*30))+" meses";
    if(s<86400*365*1000)return"~"+Math.round(s/(86400*365))+" anos";
    if(s<86400*365*1e6)return"~"+Math.round(s/(86400*365*1000))+" milênios";
    return"> 1 milhão de anos";
  }
  function fmtSecs(s){
    if(s>=3600)return(Math.floor(s/3600))+"h "+(Math.floor((s%3600)/60))+"min "+Math.floor(s%60)+"s";
    if(s>=60)return(Math.floor(s/60))+"min "+Math.floor(s%60)+"s";
    return Math.ceil(s)+"s";
  }
  function timeColor(s){if(s<60)return"var(--terra)";if(s<86400*365)return"var(--ocre)";return"var(--verde)";}
  function getCap(){return Math.max(10,Math.min(600,parseInt($('cap-input').value)||30));}
  function adjustCap(delta){const el=$('cap-input');el.value=Math.max(10,Math.min(600,(parseInt(el.value)||30)+delta));updateControls();}
  function setCap(v){$('cap-input').value=v;updateControls();}
  function updateProjection(tot){SCENARIOS.forEach(sc=>{const el=$("pt-"+sc.id),t=tot/sc.speed;el.textContent=fmtTime(t);el.style.color=timeColor(t);});}
  function erro(msg){const e=$('err-box');e.textContent=msg;e.hidden=false;}

  function updateControls(){
    const v=parseInt($('speed-sl').value);
    $('speed-lbl').innerHTML='Velocidade da simulação: <strong>'+SPEEDS[v].toLocaleString('pt-BR')+' tentativas/s</strong>';
    $('speed-hint').textContent=SPEED_HINTS[v];
    const cap=getCap();simCapMs=cap*1000;
    const label=cap>=60?(Math.floor(cap/60)+"min"+(cap%60>0?" "+cap%60+"s":"")):(cap+"s");
    $('cap-note').textContent='Limite atual: '+label+' — máx. '+(SPEEDS[v]*cap).toLocaleString('pt-BR')+' tentativas visíveis';
    refresh();
  }

  function refresh(){
    $('err-box').hidden=true;
    const pwd=$('pwd-in').value;
    const cs=CS[$('cs-sel').value];
    const ml=$('math-line'),mn=$('math-note');
    if(!pwd){ml.textContent="Digite ou gere uma senha acima";mn.textContent="";SCENARIOS.forEach(sc=>{const el=$("pt-"+sc.id);el.textContent="—";el.style.color="";});$('cap-warn').hidden=true;return;}
    const tot=Math.pow(cs.length,pwd.length);
    ml.textContent=cs.length+"^"+pwd.length+" = "+tot.toLocaleString('pt-BR')+" combinações";
    const idx=str2idx(pwd,cs);
    if(idx<0){mn.textContent="⚠ Caractere inválido para este conjunto";mn.classList.add('invalida');}
    else{mn.classList.remove('invalida');mn.textContent='"'+pwd+'" é a tentativa nº '+(idx+1).toLocaleString('pt-BR')+' ('+((idx+1)/tot*100).toFixed(1)+'% do espaço)';}
    updateProjection(tot);
    const spd=SPEEDS[parseInt($('speed-sl').value)];
    $('cap-warn').hidden=!((idx+1)/spd>getCap());
  }

  function genPwd(){
    const cs=CS[$('cs-sel').value],len=4,tot=Math.pow(cs.length,len);
    $('pwd-in').value=idx2str(Math.floor(tot*(0.55+Math.random()*0.40)),cs,len);
    refresh();
  }

  function startBF(){
    const pwd=$('pwd-in').value.trim();
    if(pwd.length<2){erro("Digite ou gere uma senha com 2 a 4 caracteres.");return;}
    const csId=$('cs-sel').value;chars=CS[csId];
    for(const c of pwd){if(!chars.includes(c)){erro('O caractere "'+c+'" não pertence ao conjunto selecionado.');return;}}
    $('err-box').hidden=true;
    pwdLen=pwd.length;targetIdx=str2idx(pwd,chars);total=Math.pow(chars.length,pwdLen);
    currentIdx=0;simSpeed=SPEEDS[parseInt($('speed-sl').value)];
    simCapMs=getCap()*1000;startTime=performance.now();running=true;
    $('prog-sec').hidden=false;$('result-sec').hidden=true;
    $('att-total').textContent=total.toLocaleString('pt-BR');
    $('start-btn').disabled=true;$('stop-btn').disabled=false;
    function tick(){
      if(!running)return;
      const elapsed=performance.now()-startTime;
      const remaining=Math.max(0,(simCapMs-elapsed)/1000);
      const timerPct=Math.min(100,elapsed/simCapMs*100);
      $('timer-display').textContent=fmtSecs(remaining);
      $('timer-bar').style.width=timerPct+'%';
      $('timer-bar').style.background=remaining<10?'var(--terra)':remaining<30?'var(--ocre)':'var(--verde)';
      const end=Math.min(Math.floor(simSpeed*elapsed/1000)+1,targetIdx+1);
      if(end>currentIdx){
        currentIdx=end;
        const cur=idx2str(end-1,chars,pwdLen),pct=end/total*100,realSpd=Math.round(end/(elapsed/1000));
        $('cur-att').textContent=cur;
        $('att-count').textContent=end.toLocaleString('pt-BR');
        $('speed-real').textContent=realSpd.toLocaleString('pt-BR')+'/s';
        $('prog-pct').textContent=pct.toFixed(2)+'%';
        $('prog-bar').style.width=Math.min(100,pct)+'%';
      }
      const capReached=elapsed>=simCapMs;
      if(currentIdx>=targetIdx+1||capReached){
        running=false;
        $('start-btn').disabled=false;$('stop-btn').disabled=true;
        $('timer-display').textContent='0s';$('timer-bar').style.width='100%';
        const elapsedSec=elapsed/1000,capApplied=capReached&&currentIdx<targetIdx+1;
        if(capApplied){$('cur-att').textContent=pwd;$('prog-bar').style.width='100%';$('prog-pct').textContent='100.00%';}
        const rDiv=$('result-sec');rDiv.className='result '+(capApplied?'capped':'found');rDiv.hidden=false;
        $('result-title').textContent=capApplied?"Tempo esgotado — senha localizada ao final":"Senha encontrada!";
        $('result-txt').textContent=
          '"'+pwd+'" encontrada na tentativa '+(targetIdx+1).toLocaleString('pt-BR')+' de '+total.toLocaleString('pt-BR')+'\n'+
          ((targetIdx+1)/total*100).toFixed(4)+'% do espaço buscado · tempo de simulação: '+elapsedSec.toFixed(2)+'s';
        addHistory(pwd,csId,total,targetIdx+1,elapsedSec,getCap(),simSpeed);
      }else{rafId=requestAnimationFrame(tick);}
    }
    rafId=requestAnimationFrame(tick);
  }

  function stopBF(){running=false;cancelAnimationFrame(rafId);$('start-btn').disabled=false;$('stop-btn').disabled=true;}
  function resetBF(){
    stopBF();
    $('prog-sec').hidden=true;$('result-sec').hidden=true;
    $('cur-att').textContent='----';$('att-count').textContent='0';
    $('speed-real').textContent='0/s';$('prog-pct').textContent='0%';
    $('prog-bar').style.width='0%';$('timer-bar').style.width='0%';
    $('timer-display').textContent='—';
  }

  function addHistory(pwd,csId,tot,found,elapsed,cap,spd){
    execucoes.unshift({pwd,csId,tot,found,elapsed,cap,spd});if(execucoes.length>8)execucoes.pop();
    const body=$('hist-body');body.innerHTML='';
    execucoes.forEach((h,i)=>{
      const capLabel=h.cap>=60?(Math.floor(h.cap/60)+"min"+(h.cap%60>0?" "+h.cap%60+"s":"")):(h.cap+"s");
      const row=document.createElement('div');
      row.className='hist-row'+(i===0?' recente':'');
      const celulas=[
        {cls:'mono destaque',txt:'"'+h.pwd+'"'},
        {cls:'obs',txt:CS_NAMES[h.csId]},
        {cls:'mono obs',txt:h.found.toLocaleString('pt-BR')},
        {cls:'mono obs',txt:h.elapsed.toFixed(1)+'s'},
        {cls:'mono obs',txt:capLabel},
        {cls:'mono obs',txt:h.spd.toLocaleString('pt-BR')+'/s'},
      ];
      for(const c of celulas){const s=document.createElement('span');s.className=c.cls;s.textContent=c.txt;row.appendChild(s);}
      body.appendChild(row);
    });
    $('hist-sec').hidden=false;
  }

  /* --- amarração dos controles --- */
  $('pwd-in').addEventListener('input',refresh);
  $('cs-sel').addEventListener('change',refresh);
  $('gen-btn').addEventListener('click',genPwd);
  $('speed-sl').addEventListener('input',updateControls);
  $('cap-input').addEventListener('input',updateControls);
  document.querySelectorAll('[data-cap-delta]').forEach(b=>b.addEventListener('click',()=>adjustCap(parseInt(b.dataset.capDelta))));
  document.querySelectorAll('[data-cap]').forEach(b=>b.addEventListener('click',()=>setCap(parseInt(b.dataset.cap))));
  $('start-btn').addEventListener('click',startBF);
  $('stop-btn').addEventListener('click',stopBF);
  $('reset-btn').addEventListener('click',resetBF);

  updateControls();
</script>
