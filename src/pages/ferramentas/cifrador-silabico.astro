---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Cifrador Silábico"
  description="Crie fichas imprimíveis de palavras e frases cifradas por sílabas ou letras — com emojis ou símbolos — para atividades de alfabetização."
>

  <!-- IBM Plex Mono + pesos 600/700 do Plex Sans carregados só nesta página.
       Playfair Display + IBM Plex Sans (300–500) já vêm do Layout. -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@600;700&display=swap" rel="stylesheet" />

  <div class="cif-root">
    <div class="wrap">

      <header class="masthead">
        <p class="eyebrow"><a href="/ferramentas">Ferramentas</a> · Alfabetização</p>
        <h1>Cifrador silábico</h1>
        <p class="lede">Cifre o texto, ajuste a ficha e imprima (ou salve em PDF). Cada linha digitada vira uma linha da ficha — dá para usar uma frase ou uma lista de palavras. O que sai no papel é só a <strong>ficha</strong> abaixo — os controles não são impressos. No modo sílaba, <code>|</code> força cortes manuais. Tudo roda no navegador.</p>
      </header>

      <!-- ================= CONTROLES ================= -->
      <div class="toolbar">
        <label class="mini" for="frase">Texto (uma frase, ou uma palavra por linha)</label>
        <textarea id="frase" class="frase-in" rows="3" spellcheck="false" autocomplete="off">O SAPO PULA NA LAGOA</textarea>

        <div class="linhaControles">
          <div class="campo"><label class="mini">Cifrar por</label>
            <div class="seg" id="modo" role="group">
              <button data-v="silaba" aria-pressed="true">sílaba</button>
              <button data-v="letra" aria-pressed="false">letra</button>
            </div></div>
          <div class="campo"><label class="mini">Chave</label>
            <div class="seg" id="chaveTipo" role="group">
              <button data-v="aleatoria" aria-pressed="true">aleatória</button>
              <button data-v="fixa" aria-pressed="false" aria-disabled="true">fixa</button>
            </div></div>
          <div class="campo"><label class="mini">Acentos e ç</label>
            <div class="seg" id="acentos" role="group">
              <button data-v="manter" aria-pressed="true">manter</button>
              <button data-v="normalizar" aria-pressed="false">normalizar</button>
            </div></div>
          <div class="campo"><label class="mini">Caixa</label>
            <div class="seg" id="caixa" role="group">
              <button data-v="alta" aria-pressed="true">ABC</button>
              <button data-v="baixa" aria-pressed="false">abc</button>
            </div></div>
          <div class="campo"><label class="mini">Figuras</label>
            <div class="seg" id="figuras" role="group">
              <button data-v="emoji" aria-pressed="true">emojis</button>
              <button data-v="simbolo" aria-pressed="false">símbolos</button>
            </div></div>
          <div class="campo"><label class="mini">Variação</label>
            <div class="semente"><input id="semente" type="number" min="1" value="1" aria-label="Variação"><button class="btn sec" id="trocar">trocar</button></div>
          </div>
        </div>

        <div class="linhaControles">
          <div class="campo" style="flex:1 1 260px"><label class="mini" for="titulo">Título da ficha</label>
            <input id="titulo" type="text" value="Vamos decifrar!"></div>
          <div class="campo" style="flex:1 1 320px"><label class="mini" for="instrucao">Instrução</label>
            <input id="instrucao" type="text" value="Use a chave e escreva embaixo de cada figura."></div>
        </div>

        <div class="opcoes">
          <label class="check"><input type="checkbox" id="optIdent" checked> Nome / Data / Turma</label>
          <label class="check"><input type="checkbox" id="optLinhas" checked> Linhas para escrever</label>
          <label class="check"><input type="checkbox" id="optGabarito"> Incluir gabarito (folha do professor)</label>
        </div>

        <div class="acoes">
          <button class="btn" id="imprimir">Imprimir / Salvar PDF</button>
          <button class="btn sec" id="copiarCifra">Copiar texto cifrado</button>
          <button class="btn sec" id="copiarChave">Copiar chave</button>
        </div>
        <div class="aviso" id="aviso" hidden></div>
      </div>

      <!-- ================= FICHA (imprime) ================= -->
      <div class="ficha" id="ficha">
        <h2 class="titulo" id="fTitulo"></h2>
        <p class="instrucao" id="fInstrucao"></p>
        <div class="ident" id="fIdent">
          <span>Nome: <span class="identline"></span></span>
          <span>Data: <span class="identline" style="min-width:5rem"></span></span>
          <span>Turma: <span class="identline" style="min-width:4rem"></span></span>
        </div>

        <div class="puzzle" id="fPuzzle"></div>

        <div class="secao-titulo">Chave</div>
        <div class="chave" id="fChave"></div>

        <div class="gabarito-page" id="fGabarito" hidden>
          <span class="selo">Gabarito — folha do professor</span>
          <div class="puzzle" id="fGabPuzzle"></div>
        </div>
      </div>

      <p class="rodape" id="resumo"></p>
    </div>
  </div>

</Layout>

<style is:global>
  /* ============================================================
     Ferramenta: Cifrador silábico
     CSS escopado sob .cif-root para não vazar para o resto do site.
     Variáveis no próprio .cif-root.
     ============================================================ */

  .cif-root{
    --papel:#F8F6F1; --tinta:#1B4F4F; --tinta-2:#2f6b6b;
    --traco:#d8d2c4; --realce:#c2410c; --neutro:#6b6459;

    background:var(--papel); color:var(--tinta);
    font-family:'IBM Plex Sans',system-ui,sans-serif; line-height:1.5;
    padding:2rem 1.2rem 4rem;
  }
  .cif-root [hidden]{ display:none !important; }   /* vence display:flex/grid explícitos */
  .cif-root .wrap{ max-width:900px; margin:0 auto; }

  .cif-root .masthead{ margin-bottom:1.4rem; }
  .cif-root .masthead .eyebrow{
    font-family:'IBM Plex Mono',ui-monospace,monospace; font-size:0.75rem;
    letter-spacing:0.12em; text-transform:uppercase; color:var(--neutro); margin:0 0 .6rem;
  }
  .cif-root .masthead .eyebrow a{ color:inherit; text-decoration:none; }
  .cif-root .masthead .eyebrow a:hover{ color:var(--tinta); }
  .cif-root .masthead h1{ font-family:'Playfair Display',Georgia,serif; font-weight:700;
    font-size:clamp(1.6rem,4vw,2.2rem); margin:0 0 .2rem; }
  .cif-root .masthead .lede{ color:var(--neutro); margin:0; font-size:.95rem; }
  .cif-root .masthead .lede code{ background:#fff; padding:.05em .35em; border-radius:4px; font-family:'IBM Plex Mono',monospace; font-size:.85em; }

  /* ---------- barra de controles (não imprime) ---------- */
  .cif-root .toolbar{ background:#fff; border:1px solid var(--traco); border-radius:12px; padding:1.1rem 1.2rem; }
  .cif-root label.mini{ display:block; font-weight:600; font-size:.74rem; text-transform:uppercase;
    letter-spacing:.06em; margin:0 0 .35rem; color:var(--tinta-2); }
  .cif-root input[type=text], .cif-root textarea{ width:100%; background:#fff; border:1px solid var(--traco); border-radius:9px;
    padding:.6rem .8rem; font:inherit; color:var(--tinta); }
  .cif-root input[type=text]:focus, .cif-root input:focus, .cif-root textarea:focus{ outline:2px solid var(--tinta); outline-offset:1px; }
  .cif-root .frase-in{ font-size:1.1rem; resize:vertical; line-height:1.5; }
  .cif-root .linhaControles{ display:flex; flex-wrap:wrap; gap:1rem 1.4rem; align-items:flex-end; margin-top:1rem; }
  .cif-root .campo{ display:flex; flex-direction:column; gap:.35rem; }
  .cif-root .seg{ display:inline-flex; border:1px solid var(--traco); border-radius:8px; overflow:hidden; }
  .cif-root .seg button{ background:#fff; color:var(--tinta); border:0; border-radius:0; font:inherit;
    font-weight:500; padding:.45rem .8rem; cursor:pointer; }
  .cif-root .seg button[aria-pressed="true"]{ background:var(--tinta); color:var(--papel); }
  .cif-root .seg button[aria-disabled="true"]{ color:#b7b0a3; cursor:not-allowed; background:#f3f0e8; }
  .cif-root .semente{ display:flex; gap:.4rem; align-items:center; }
  .cif-root .semente input{ width:4rem; background:#fff; border:1px solid var(--traco); border-radius:8px; padding:.45rem; font:inherit; text-align:center; }
  .cif-root .btn{ background:var(--tinta); color:var(--papel); border:0; border-radius:8px; padding:.5rem .85rem; font:inherit; font-weight:600; cursor:pointer; }
  .cif-root .btn:hover{ background:var(--tinta-2); }
  .cif-root .btn.sec{ background:#fff; color:var(--tinta); border:1px solid var(--traco); }
  .cif-root .btn.sec:hover{ background:var(--papel); }
  .cif-root .check{ display:inline-flex; align-items:center; gap:.4rem; font-size:.88rem; color:var(--tinta-2); font-weight:500; cursor:pointer; }
  .cif-root .opcoes{ display:flex; flex-wrap:wrap; gap:.6rem 1.3rem; margin-top:1rem; padding-top:.9rem; border-top:1px solid var(--traco); }
  .cif-root .acoes{ display:flex; flex-wrap:wrap; gap:.6rem; margin-top:1rem; }
  .cif-root .aviso{ margin-top:.7rem; color:var(--realce); font-weight:600; font-size:.9rem; }

  /* ---------- a FICHA (isto é o que imprime) ---------- */
  .cif-root .ficha{ background:#fff; margin:1.6rem auto 0; padding:16mm 15mm; max-width:210mm;
    border:1px solid var(--traco); border-radius:6px; box-shadow:0 8px 30px rgba(27,79,79,.08);
    color:#1a1a1a; }
  .cif-root .ficha .titulo{ font-family:'Playfair Display',serif; font-weight:700; font-size:1.8rem; margin:0 0 .3rem; color:var(--tinta); }
  .cif-root .ficha .instrucao{ font-size:1rem; margin:0 0 1rem; color:#333; }
  .cif-root .ficha .ident{ display:flex; gap:1.5rem; flex-wrap:wrap; font-size:.95rem; color:#333;
    border-bottom:1px solid var(--traco); padding-bottom:.8rem; margin-bottom:1.2rem; }
  .cif-root .ficha .ident span{ flex:1 1 auto; }
  .cif-root .ficha .identline{ display:inline-block; border-bottom:1px solid #999; min-width:8rem; }

  .cif-root .puzzle{ display:flex; flex-direction:column; gap:.3rem; }
  .cif-root .plinha{ display:flex; flex-wrap:wrap; }   /* uma linha do texto digitado */
  .cif-root .word{ display:inline-flex; gap:.35rem; margin:.35rem 1.1rem .35rem 0; padding:.2rem; }
  .cif-root .unit{ display:inline-flex; flex-direction:column; align-items:center; min-width:2.5em; }
  .cif-root .unit .emoji{ font-size:2.1rem; line-height:1.3; }
  .cif-root .unit .linha{ width:100%; min-width:2.4em; height:2.2em; border-bottom:1.6px solid #444; margin-top:.15rem; }
  .cif-root .unit .sol{ font-family:'IBM Plex Mono',monospace; font-size:1.05rem; font-weight:600; color:var(--realce); margin-top:.2rem; }

  .cif-root .secao-titulo{ font-family:'IBM Plex Sans',sans-serif; font-weight:700; font-size:.8rem; text-transform:uppercase;
    letter-spacing:.08em; color:var(--tinta-2); margin:1.6rem 0 .7rem; }
  .cif-root .chave{ display:flex; flex-wrap:wrap; gap:.5rem; }
  .cif-root .card{ display:flex; align-items:center; gap:.4rem; border:1.4px solid var(--traco);
    border-radius:8px; padding:.3rem .6rem; }
  .cif-root .card .emoji{ font-size:1.5rem; }
  .cif-root .card .eq{ color:#999; }
  .cif-root .card .u{ font-weight:700; font-size:1.05rem; font-family:'IBM Plex Mono',monospace; }

  .cif-root .gabarito-page{ margin-top:2rem; }
  .cif-root .selo{ display:inline-block; background:var(--realce); color:#fff; font-size:.72rem; font-weight:700;
    text-transform:uppercase; letter-spacing:.08em; padding:.2em .6em; border-radius:99px; margin-bottom:.6rem; }

  .cif-root .rodape{ margin-top:2rem; font-size:.82rem; color:var(--neutro); }

  /* ---------- IMPRESSÃO: só a ficha sai no papel ---------- */
  @media print{
    @page{ size:A4; margin:12mm; }
    html, body{ background:#fff !important; }
    body > nav{ display:none !important; }   /* navegação do site */
    .cif-root{ background:#fff; padding:0; }
    .cif-root .masthead, .cif-root .toolbar, .cif-root .rodape{ display:none !important; }
    .cif-root .ficha{ margin:0; padding:0; max-width:none; border:0; border-radius:0; box-shadow:none; }
    .cif-root .word, .cif-root .card, .cif-root .unit{ break-inside:avoid; }
    .cif-root .gabarito-page{ break-before:page; }
    .cif-root *{ -webkit-print-color-adjust:exact; print-color-adjust:exact; }
  }
</style>

<script is:inline>
/* ==========================================================================
   1) SILABADOR
   ========================================================================== */
const VOGAIS="aeiouáàâãéêíóôõúäëïöüy", FORTE="aeoáàâãéêóôõ", FRACA="iuü",
      FRACA_ACENT="íúìùû", MUDA="pbtdcgfv", LIQUIDA="lr";
const ehVogal=c=>VOGAIS.includes(c);
function juntaVogais(a,b){
  if(FRACA_ACENT.includes(a)||FRACA_ACENT.includes(b))return false;
  if(FORTE.includes(a)&&FORTE.includes(b))return false;
  if(FRACA.includes(a)&&FRACA.includes(b))return true;
  if(FORTE.includes(a)&&FRACA.includes(b))return true;
  if(FRACA.includes(a)&&FORTE.includes(b))return false;
  return false;
}
function dividirCorridaVogais(run,prev){
  const nuc=[]; let atual=run[0];
  for(let p=1;p<run.length;p++){
    const a=atual[atual.length-1], b=run[p];
    let junta=(p===1&&atual==="u"&&(prev==="g"||prev==="q")&&FORTE.includes(b))?true:juntaVogais(a,b);
    if(junta)atual+=b; else{ nuc.push(atual); atual=b; }
  }
  nuc.push(atual); return nuc;
}
function silabar(palavra){
  const orig=palavra, w=palavra.toLowerCase(), n=w.length;
  if(n===0)return[orig];
  const tokens=[]; let i=0;
  while(i<n){
    const c=w[i],c2=w[i+1]||"",c3=w[i+2]||"";
    if((c==="c"&&c2==="h")||(c==="l"&&c2==="h")||(c==="n"&&c2==="h")){tokens.push({type:"C",ini:i,fim:i+2});i+=2;continue;}
    if((c==="q"||c==="g")&&c2==="u"&&"eiéêí".includes(c3)){tokens.push({type:"C",ini:i,fim:i+2});i+=2;continue;}
    if(ehVogal(c)){
      let j=i; while(j<n&&ehVogal(w[j]))j++;
      const prev=i>0?w[i-1]:"";
      const nucs=dividirCorridaVogais(w.slice(i,j),prev);
      let k=i; for(const nu of nucs){tokens.push({type:"V",ini:k,fim:k+nu.length});k+=nu.length;}
      i=j; continue;
    }
    tokens.push({type:"C",ini:i,fim:i+1}); i++;
  }
  const nuc=[]; tokens.forEach((t,idx)=>{if(t.type==="V")nuc.push(idx);});
  if(nuc.length===0)return[orig];
  const syl=new Array(tokens.length).fill(-1);
  nuc.forEach((tk,s)=>syl[tk]=s);
  for(let t=0;t<nuc[0];t++)syl[t]=0;
  for(let t=nuc[nuc.length-1]+1;t<tokens.length;t++)syl[t]=nuc.length-1;
  for(let s=0;s<nuc.length-1;s++){
    const esq=nuc[s],dir=nuc[s+1],run=[];
    for(let t=esq+1;t<dir;t++)run.push(t);
    const m=run.length; if(m===0)continue;
    let ataque=1;
    if(m>=2){
      const t1=tokens[run[m-2]],t2=tokens[run[m-1]];
      const a1=(t1.fim-t1.ini===1)?w[t1.ini]:null, a2=(t2.fim-t2.ini===1)?w[t2.ini]:null;
      if(a1&&a2&&MUDA.includes(a1)&&LIQUIDA.includes(a2))ataque=2;
    }
    for(let x=0;x<m;x++)syl[run[x]]=(x<m-ataque)?s:s+1;
  }
  const S=nuc.length, silabas=[];
  for(let s=0;s<S;s++){
    let ini=Infinity,fim=-1;
    tokens.forEach((t,idx)=>{if(syl[idx]===s){ini=Math.min(ini,t.ini);fim=Math.max(fim,t.fim);}});
    silabas.push(orig.slice(ini,fim));
  }
  return silabas;
}

/* ==========================================================================
   2) EMOJIS  (MNEMONICO = chave fixa por inicial; POOL = aleatório)
   ========================================================================== */
const MNEMONICO = { // emoji escolhido pela inicial; a palavra NÃO é impressa
  a:"🍍", b:"🍌", c:"🏠", d:"🎲", e:"🐘", f:"🔥", g:"🐱", h:"🦛", i:"🏝",
  j:"🐊", k:"🥝", l:"🦁", m:"🍎", n:"☁️", o:"🥚", p:"🐧", q:"🧀", r:"🐭",
  s:"☀️", t:"🐢", u:"🍇", v:"🐮", w:"🧇", x:"☕", y:"🪀", z:"🦓"
};
const POOL = [
 "🐶","🐹","🐰","🦊","🐻","🐼","🐨","🐯","🐷","🐸","🐵","🐔","🐤","🦉","🐺","🐴","🦄",
 "🐝","🐛","🦋","🐌","🐞","🐍","🐙","🦀","🐠","🐬","🐳","🦈","🦒","🐐","🐑","🐎","🦔","🦕","🦖",
 "🍐","🍊","🍋","🍉","🍒","🍑","🥭","🥕","🌽","🍄","🥐","🥨","🍕","🍩","🍪","🎂","🧁","🍫","🍬","🍭","🍿",
 "🌵","🌳","🌴","🌱","🍀","🍁","🌷","🌻","🌸","💐","⭐","🌈","🌙","❄️","⛄","💧","🌊",
 "⚽","🏀","🎾","🎯","🧩","🎈","🎁","🔔","🎺","🎸","🎻","🥁","🎹","🚗","🚌","🚲","🚂","✈️","🚀","🚁","⛵",
 "🏰","⛺","🎡","🎠","🧸","🎨","✏️","📚","🔑","⏰","🪁","🌂","🕯","🥇","💎","🎳"
];

/* Conjunto monocromático (preto e branco): estrelas, formas, naipes, peças de
   xadrez, notas, dados e alguns pictogramas. O seletor de variação de texto
   (U+FE0E) força a apresentação em glifo, impedindo o navegador de trocar por
   versões coloridas de emoji. Símbolos distintos das letras usuais. */
const SIMBOLOS_BASE = [
 "★","☆","✦","✧","✩","✪","✫","✬","✭","✮","✯","✰","✶","✷","✸","✹","✺",
 "✿","❀","❁","❂","❃","❄","❅","❆","❇","❈","❉","❊","❋",
 "●","○","◆","◇","■","□","▲","△","▼","▽","◀","▶",
 "♠","♣","♥","♦","♩","♪","♫","♬",
 "♔","♕","♖","♗","♘","♙","♚","♛","♜","♝","♞","♟",
 "⚀","⚁","⚂","⚃","⚄","⚅",
 "☀","☁","☂","☃","☘","☯","☮","⚓","⌂","✈","✉","✂","✎"
];
const POOL_SIMBOLOS = SIMBOLOS_BASE.map(s=>s+"\uFE0E");

/* ==========================================================================
   3) PRNG com semente (reprodutibilidade)
   ========================================================================== */
function xmur3(str){ let h=1779033703^str.length;
  for(let i=0;i<str.length;i++){ h=Math.imul(h^str.charCodeAt(i),3432918353); h=(h<<13)|(h>>>19); }
  return function(){ h=Math.imul(h^(h>>>16),2246822507); h=Math.imul(h^(h>>>13),3266489909); return (h^=h>>>16)>>>0; };
}
function mulberry32(a){ return function(){ a|=0; a=(a+0x6D2B79F5)|0; let t=Math.imul(a^(a>>>15),1|a);
  t=(t+Math.imul(t^(t>>>7),61|t))^t; return ((t^(t>>>14))>>>0)/4294967296; }; }
function embaralhar(arr,semente){ const rng=mulberry32(xmur3("shuffle:"+semente)()); const a=arr.slice();
  for(let i=a.length-1;i>0;i--){ const j=Math.floor(rng()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; } return a; }

/* ==========================================================================
   4) MOTOR DE CIFRAGEM
   ========================================================================== */
function ajustar(u,opts){
  let s=u;
  if(opts.semAcento) s=s.normalize("NFD").replace(/[\u0300-\u036f]/g,"");
  return opts.maiusc? s.toUpperCase():s.toLowerCase();
}
/* Cada linha do texto vira uma linha da ficha; dentro dela, palavras separadas
   por espaço. Devolve um array de linhas, cada uma com suas palavras. */
function extrair(texto, est, opts){
  const linhas=[];
  for(const linha of texto.split(/\n/)){
    const palavras=[];
    for(const bruto of linha.split(/(\s+)/)){
      if(/^\s+$/.test(bruto)) continue;
      const limpo=bruto.replace(/[^A-Za-zÀ-ÿ|]/g,"");
      if(!limpo) continue;
      let pedacos;
      if(est.modo==="silaba"){
        pedacos = limpo.includes("|") ? limpo.split("|").filter(x=>x.length) : silabar(limpo.replace(/\|/g,""));
      } else {
        pedacos = limpo.replace(/\|/g,"").split("");
      }
      const unidades=pedacos.map(p=>ajustar(p,opts)).filter(x=>x.length);
      if(unidades.length) palavras.push({unidades});
    }
    if(palavras.length) linhas.push(palavras);
  }
  return linhas;
}
function poolAtivo(est){ return est.figuras==="simbolo" ? POOL_SIMBOLOS : POOL; }
function construirChave(unicas, est){
  const usados=new Set(), chave=new Map(); let faltou=false;
  const pool=embaralhar(poolAtivo(est), est.semente); let pi=0;
  const doPool=()=>{ while(pi<pool.length&&usados.has(pool[pi]))pi++;
    if(pi>=pool.length){faltou=true;return "❓";} const e=pool[pi++]; usados.add(e); return e; };
  for(const u of unicas){
    let emoji=null;
    // A chave fixa é mnemônica (figura pela inicial), então só faz sentido com emojis.
    if(est.modo==="letra"&&est.chaveTipo==="fixa"&&est.figuras==="emoji"){
      const m=MNEMONICO[u.toLowerCase()];
      if(m&&!usados.has(m)){ emoji=m; usados.add(m); }
    }
    if(!emoji) emoji=doPool();
    chave.set(u,emoji);
  }
  return {chave,faltou};
}

/* ==========================================================================
   5) ESTADO + RENDER
   ========================================================================== */
const est={ modo:"silaba", chaveTipo:"aleatoria", acentos:"manter", caixa:"alta", figuras:"emoji", semente:1 };
const $=id=>document.getElementById(id);

function gerar(){
  est.semente=Math.max(1,parseInt($("semente").value||"1",10));
  const opts={ maiusc: est.caixa==="alta", semAcento: est.acentos==="normalizar" };
  const linhas=extrair($("frase").value, est, opts);
  const unidades=[]; linhas.forEach(l=>l.forEach(t=>t.unidades.forEach(u=>unidades.push(u))));
  const unicas=[...new Set(unidades)].sort((a,b)=>a.localeCompare(b,"pt"));
  const {chave,faltou}=construirChave(unicas, est);

  // cabeçalho
  $("fTitulo").textContent=$("titulo").value||" ";
  $("fInstrucao").textContent=$("instrucao").value||"";
  $("fIdent").hidden=!$("optIdent").checked;

  // puzzle do aluno
  renderUnidades($("fPuzzle"), linhas, chave, {linhas:$("optLinhas").checked, resolver:false});
  // chave
  renderChave($("fChave"), unicas, chave);
  // gabarito
  const g=$("fGabarito");
  if($("optGabarito").checked){ g.hidden=false; renderUnidades($("fGabPuzzle"), linhas, chave, {linhas:false, resolver:true}); }
  else g.hidden=true;

  const av=$("aviso");
  if(faltou){ av.hidden=false; av.textContent="O texto tem mais unidades distintas do que o conjunto comporta ("+poolAtivo(est).length+" figuras). Encurte o texto ou troque o conjunto."; }
  else av.hidden=true;

  const nPalavras=linhas.reduce((n,l)=>n+l.length,0);
  $("resumo").textContent=linhas.length+" linha(s) · "+nPalavras+" palavra(s) · "+unidades.length+" unidade(s) · "+unicas.length+" símbolo(s) na chave · "+
    (est.modo==="letra"&&est.chaveTipo==="fixa"?"chave fixa":"chave aleatória (semente "+est.semente+")");

  window._ult={linhas,chave,unicas};
}

function renderUnidades(alvo, linhasTexto, chave, {linhas, resolver}){
  alvo.innerHTML="";
  if(!linhasTexto.length){ alvo.innerHTML='<span style="color:#999">Digite uma frase ou uma lista de palavras.</span>'; return; }
  for(const palavras of linhasTexto){
    const row=document.createElement("div"); row.className="plinha";
    for(const t of palavras){
      const w=document.createElement("span"); w.className="word";
      for(const u of t.unidades){
        const un=document.createElement("span"); un.className="unit";
        const em=document.createElement("span"); em.className="emoji"; em.textContent=chave.get(u)||"❓";
        un.appendChild(em);
        if(resolver){ const s=document.createElement("span"); s.className="sol"; s.textContent=u; un.appendChild(s); }
        else if(linhas){ const l=document.createElement("span"); l.className="linha"; un.appendChild(l); }
        w.appendChild(un);
      }
      row.appendChild(w);
    }
    alvo.appendChild(row);
  }
}
function renderChave(alvo, unicas, chave){
  alvo.innerHTML="";
  for(const u of unicas){
    const c=document.createElement("span"); c.className="card";
    const em=document.createElement("span"); em.className="emoji"; em.textContent=chave.get(u);
    const eq=document.createElement("span"); eq.className="eq"; eq.textContent="=";
    const un=document.createElement("span"); un.className="u"; un.textContent=u;
    c.append(em,eq,un); alvo.appendChild(c);
  }
}

/* --- cópia (com fallback) --- */
async function copiar(texto, botao){
  try{ await navigator.clipboard.writeText(texto); }
  catch(e){ const ta=document.createElement("textarea"); ta.value=texto; ta.style.position="fixed"; ta.style.opacity="0";
    document.body.appendChild(ta); ta.select(); try{document.execCommand("copy");}catch(_){} document.body.removeChild(ta); }
  const orig=botao.textContent; botao.textContent="copiado!"; setTimeout(()=>botao.textContent=orig,1200);
}
function textoCifra(){ const {linhas,chave}=window._ult||{linhas:[]};
  return linhas.map(l=>l.map(w=>w.unidades.map(u=>chave.get(u)||"❓").join("")).join("  ")).join("\n"); }
function textoChave(){ const {unicas,chave}=window._ult||{unicas:[]};
  return unicas.map(u=>chave.get(u)+" = "+u).join("\n"); }

/* --- controles --- */
function ligarSeg(id,chaveEstado,aoMudar){
  document.querySelectorAll("#"+id+" button").forEach(b=>{
    b.addEventListener("click",()=>{ if(b.getAttribute("aria-disabled")==="true")return;
      document.querySelectorAll("#"+id+" button").forEach(x=>x.setAttribute("aria-pressed",x===b));
      est[chaveEstado]=b.dataset.v; if(aoMudar)aoMudar(); gerar(); });
  });
}
// A chave "fixa" só existe no modo letra + emojis (é mnemônica pela inicial).
function atualizarFixa(){
  const fixa=document.querySelector('#chaveTipo button[data-v="fixa"]');
  if(est.modo==="letra"&&est.figuras==="emoji") fixa.setAttribute("aria-disabled","false");
  else{ fixa.setAttribute("aria-disabled","true"); est.chaveTipo="aleatoria";
    document.querySelectorAll("#chaveTipo button").forEach(x=>x.setAttribute("aria-pressed",x.dataset.v==="aleatoria")); }
}
ligarSeg("modo","modo",atualizarFixa);
ligarSeg("figuras","figuras",atualizarFixa);
ligarSeg("chaveTipo","chaveTipo"); ligarSeg("acentos","acentos"); ligarSeg("caixa","caixa");
["frase","titulo","instrucao","semente"].forEach(id=>$(id).addEventListener("input",gerar));
["optIdent","optLinhas","optGabarito"].forEach(id=>$(id).addEventListener("change",gerar));
$("trocar").addEventListener("click",()=>{ $("semente").value=(parseInt($("semente").value||"1",10)+1); gerar(); });
$("imprimir").addEventListener("click",()=>window.print());
$("copiarCifra").addEventListener("click",e=>copiar(textoCifra(),e.target));
$("copiarChave").addEventListener("click",e=>copiar(textoChave(),e.target));

gerar();
</script>
