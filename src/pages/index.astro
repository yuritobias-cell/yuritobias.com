---
import Layout from '../layouts/Layout.astro';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Yuri Tobias',
  url: Astro.site?.toString(),
  jobTitle: ['Professor de Matemática', 'Analista de Dados Educacionais'],
  worksFor: [
    { '@type': 'Organization', name: 'Escola SESI Poços de Caldas' },
    { '@type': 'Organization', name: 'Secretaria Municipal de Educação de Poços de Caldas' },
  ],
  sameAs: [
    'https://www.linkedin.com/in/yuri-tobias-aquiel-correa-ramos-754184104/',
    'https://lattes.cnpq.br/2782196498099761',
  ],
};
---

<Layout title="Sobre" schema={schema}>
  <main>
    <header>
      <h1>Yuri Tobias</h1>
      <p class="roles">
        Professor de Matemática
        <span class="sep">·</span>
        Analista de Dados Educacionais
      </p>
    </header>

    <div class="divider"></div>

    <section class="bio">
      <p>
        Trabalho na Secretaria Municipal de Educação de Poços de Caldas
        com análise de dados educacionais e na Escola SESI como professor de
        matemática para o Ensino Fundamental e o Ensino Médio.
      </p>
      <p>
        Este site reúne projetos, materiais didáticos e reflexões sobre
        os dois campos em que atuo — dados e ensino.
      </p>
    </section>

    <nav class="links">
      <a href="mailto:yuritobias@gmail.com">E-mail</a>
      <a href="https://www.linkedin.com/in/yuri-tobias-aquiel-correa-ramos-754184104/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://lattes.cnpq.br/2782196498099761" target="_blank" rel="noopener">Lattes</a>
    </nav>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: calc(100dvh - 68px);
    max-width: 580px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    animation: fade-up 0.6s ease both;
  }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 0.6rem;
  }

  .roles { font-size: 0.95rem; font-weight: 300; color: var(--muted); }
  .sep { margin: 0 0.5rem; opacity: 0.5; }

  .divider {
    width: 2.5rem;
    height: 2px;
    background: var(--accent);
    margin: 2rem 0;
  }

  .bio { display: flex; flex-direction: column; gap: 0.9rem; margin-bottom: 2.5rem; }

  .bio p { font-size: 1rem; line-height: 1.75; opacity: 0.85; }

  .links { display: flex; gap: 1.75rem; flex-wrap: wrap; }

  .links a {
    text-decoration: none;
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    position: relative;
    padding-bottom: 2px;
  }

  .links a::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0;
    width: 0; height: 1px;
    background: var(--accent);
    transition: width 0.25s ease;
  }

  .links a:hover::after { width: 100%; }
</style>