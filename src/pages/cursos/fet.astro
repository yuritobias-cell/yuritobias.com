---
import Layout from '../../layouts/Layout.astro';
import curso from '../../data/curso-fet.json';

const aulas = curso.aulas.filter(a => a.tipo === 'aula');
const extras = curso.aulas.filter(a => a.tipo === 'extra');

function thumbnail(url) {
  const id = url.split('youtu.be/')[1]?.split('?')[0];
  return id ? `https://img.youtube.com/vi/${id}/mqdefault.jpg` : '';
}
---

<Layout title={curso.titulo}>
  <main>
    <div class="cabecalho">
      <h1>{curso.titulo}</h1>
      <p class="descricao">{curso.descricao}</p>
      <a href={curso.playlist} target="_blank" rel="noopener noreferrer" class="btn-playlist">
        ▶ Ver playlist completa no YouTube
      </a>
    </div>

    <section>
      <h2>Aulas</h2>
      <ol class="lista-aulas">
        {aulas.map(aula => (
          <li class="item-aula">
            <a href={aula.url} target="_blank" rel="noopener noreferrer" class="thumb" tabindex="-1">
              <img src={thumbnail(aula.url)} alt="" width="120" height="68" loading="lazy" />
            </a>
            <span class="numero">Aula {aula.n}</span>
            <span class="titulo-aula">{aula.titulo}</span>
            <a href={aula.url} target="_blank" rel="noopener noreferrer" class="btn-assistir">
              ▶ Assistir
            </a>
          </li>
        ))}
      </ol>
    </section>

    <section>
      <h2>Aulas extras</h2>
      <ol class="lista-aulas">
        {extras.map(extra => (
          <li class="item-aula">
            <a href={extra.url} target="_blank" rel="noopener noreferrer" class="thumb" tabindex="-1">
              <img src={thumbnail(extra.url)} alt="" width="120" height="68" loading="lazy" />
            </a>
            <span class="numero">Extra {extra.n}</span>
            <span class="titulo-aula">{extra.titulo}</span>
            <a href={extra.url} target="_blank" rel="noopener noreferrer" class="btn-assistir">
              ▶ Assistir
            </a>
          </li>
        ))}
      </ol>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .cabecalho {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--rule);
  }

  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    color: var(--ink);
    margin-bottom: 0.5rem;
  }

  .descricao {
    color: var(--muted);
    margin-bottom: 1.25rem;
  }

  .btn-playlist {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #fff;
    background-color: var(--accent);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .btn-playlist:hover {
    background-color: #163d3d;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  section {
    margin-bottom: 2.5rem;
  }

  .lista-aulas {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .item-aula {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background-color: #fff;
    border: 1px solid var(--rule);
    border-radius: 6px;
  }

  .thumb { flex-shrink: 0; line-height: 0; }

  .thumb img {
    width: 120px;
    height: 68px;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  @media (max-width: 560px) {
    .item-aula { flex-wrap: wrap; }
    .thumb img { width: 96px; height: 54px; }
    .titulo-aula { flex-basis: 100%; order: 3; }
  }

  .numero {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    white-space: nowrap;
    min-width: 4.5rem;
  }

  .titulo-aula {
    flex: 1;
    font-size: 0.95rem;
    color: var(--ink);
  }

  .btn-assistir {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    border: 1px solid var(--accent);
    padding: 0.3rem 0.75rem;
    border-radius: 4px;
    transition: background-color 0.2s, color 0.2s;
  }

  .btn-assistir:hover {
    background-color: var(--accent);
    color: #fff;
  }
</style>