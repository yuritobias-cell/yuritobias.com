---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Tags from '../../components/Tags.astro';
import { minutosDeLeitura } from '../../utils/leitura';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(post => !post.data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const minutos = minutosDeLeitura(post.body ?? '');

// Imagem OG do post, gerada no build por src/pages/og/[slug].png.ts.
const ogImage = `/og/${post.id}.png`;

const urlPost = new URL(Astro.url.pathname, Astro.site).toString();
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  inLanguage: 'pt-BR',
  image: new URL(ogImage, Astro.site).toString(),
  url: urlPost,
  mainEntityOfPage: urlPost,
  keywords: post.data.tags,
  author: {
    '@type': 'Person',
    name: 'Yuri Tobias',
    url: Astro.site?.toString(),
  },
};

const publicados = (await getCollection('blog')).filter(p => !p.data.draft);

// Postagens da mesma série, ordenadas pela parte.
const partesDaSerie = post.data.series
  ? publicados
      .filter(p => p.data.series === post.data.series)
      .sort((a, b) => (a.data.part ?? 0) - (b.data.part ?? 0))
  : [];

// Vizinhos cronológicos (todas as postagens, da mais antiga para a mais nova).
const cronologia = [...publicados].sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const indiceCrono = cronologia.findIndex(p => p.id === post.id);
const postAnterior = indiceCrono > 0 ? cronologia[indiceCrono - 1] : null;
const postSeguinte = indiceCrono >= 0 && indiceCrono < cronologia.length - 1
  ? cronologia[indiceCrono + 1]
  : null;
---

<Layout title={post.data.title} description={post.data.description} ogImage={ogImage} ogType="article" schema={schema}>
  <main class="max-w-2xl mx-auto px-6 py-16">

    <a href="/blog" class="text-sm text-stone-400 hover:text-[var(--color-accent)] transition-colors mb-8 block">
      ← Blog
    </a>

    <p class="text-sm text-stone-400">
      <time>
        {post.data.date.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric', timeZone: 'UTC' })}
      </time>
      <span aria-hidden="true"> · </span>{minutos} min de leitura
    </p>

    <h1 class="text-4xl font-display mt-2 mb-4">{post.data.title}</h1>
    <p class="text-stone-500 mb-4 text-base">{post.data.description}</p>

    <div class="mb-10">
      <Tags tags={post.data.tags} />
    </div>

    <hr class="border-stone-200 mb-10" />

    {post.data.series && (
      <aside aria-label="Série" class="mb-10 rounded-lg border border-stone-200 p-5">
        <p class="text-sm text-stone-500 mb-2">
          {partesDaSerie.length > 1
            ? <>Parte {post.data.part} da série <strong class="text-[var(--color-ink)]">{post.data.series}</strong></>
            : <>Esta postagem abre a série <strong class="text-[var(--color-ink)]">{post.data.series}</strong> — as próximas partes aparecerão aqui.</>}
        </p>
        {partesDaSerie.length > 1 && (
          <ol class="text-sm space-y-1 list-none">
            {partesDaSerie.map(p => (
              <li>
                <span class="text-stone-400">{p.data.part}.</span>{' '}
                {p.id === post.id
                  ? <span class="font-semibold">{p.data.title}</span>
                  : <a href={`/blog/${p.id}`} class="text-[var(--color-accent)] underline hover:no-underline">{p.data.title}</a>}
              </li>
            ))}
          </ol>
        )}
      </aside>
    )}

    <article class="
      text-[var(--color-ink)]
      [&_h2]:text-2xl [&_h2]:font-display [&_h2]:mt-10 [&_h2]:mb-3
      [&_h3]:text-xl [&_h3]:font-display [&_h3]:mt-8 [&_h3]:mb-2
      [&_p]:leading-relaxed [&_p]:mb-5
      [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-5 [&_ul>li]:mb-1
      [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-5
      [&_a]:text-[var(--color-accent)] [&_a]:underline
      [&_strong]:font-semibold
      [&_code]:bg-stone-100 [&_code]:px-1 [&_code]:rounded [&_code]:text-sm
      [&_blockquote]:border-l-4 [&_blockquote]:border-stone-300 [&_blockquote]:pl-4 [&_blockquote]:text-stone-500
    ">
      <Content />
    </article>

    {(postAnterior || postSeguinte) && (
      <nav aria-label="Outras postagens" class="mt-12 pt-6 border-t border-stone-200 flex justify-between gap-6 text-sm">
        <div>
          {postAnterior && (
            <a href={`/blog/${postAnterior.id}`} class="group block">
              <span class="block text-stone-400 mb-1">← Anterior</span>
              <span class="text-[var(--color-accent)] group-hover:underline">{postAnterior.data.title}</span>
            </a>
          )}
        </div>
        <div class="text-right">
          {postSeguinte && (
            <a href={`/blog/${postSeguinte.id}`} class="group block">
              <span class="block text-stone-400 mb-1">Próxima →</span>
              <span class="text-[var(--color-accent)] group-hover:underline">{postSeguinte.data.title}</span>
            </a>
          )}
        </div>
      </nav>
    )}

  </main>
</Layout>