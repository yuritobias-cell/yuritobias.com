---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Analista de dados educacionais e professor de matemática em Poços de Caldas." } = Astro.props;
const pathname = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title === 'Sobre' ? 'Yuri Tobias' : `${title} · Yuri Tobias`}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav>
      <a href="/" class="brand">Yuri Tobias</a>
      <div class="nav-links">
        <a href="/" class:list={[{ active: pathname === '/' }]}>Sobre</a>
        <a href="/materiais" class:list={[{ active: pathname.startsWith('/materiais') }]}>Materiais</a>
        <a href="/ferramentas" class:list={[{ active: pathname.startsWith('/ferramentas') }]}>Ferramentas</a>
        <a href="/cursos" class:list={[{ active: pathname.startsWith('/cursos') }]}>Cursos</a>
        <a href="/blog" class:list={[{ active: pathname.startsWith('/blog') }]}>Blog</a>
      </div>
    </nav>
    <slot />
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:           #F8F6F1;
    --ink:          #1C1917;
    --muted:        #78716C;
    --accent:       #1B4F4F;
    --rule:         #E2DDD6;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body:    'IBM Plex Sans', system-ui, sans-serif;
  }

  html {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  body { min-height: 100dvh; }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--rule);
  }

  .brand {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
  }

  .nav-links { display: flex; gap: 2rem; }

  .nav-links a {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .nav-links a:hover,
  .nav-links a.active { color: var(--accent); }
  .nav-links a.active { font-weight: 500; }
</style>