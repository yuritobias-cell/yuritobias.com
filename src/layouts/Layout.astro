---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Analista de dados educacionais e professor de matemática em Poços de Caldas." } = Astro.props;
const pathname = Astro.url.pathname;
const tituloCompleto = title === 'Sobre' ? 'Yuri Tobias' : `${title} · Yuri Tobias`;
const canonical = new URL(pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{tituloCompleto}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Yuri Tobias" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Yuri Tobias — Professor de Matemática e Analista de Dados Educacionais" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tituloCompleto} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og.png', Astro.site)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Blog · Yuri Tobias" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <script is:inline data-goatcounter="https://yuritobias.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
    <script is:inline>
      // Registra downloads de PDF como eventos no GoatCounter
      document.addEventListener('click', function (e) {
        var link = e.target.closest && e.target.closest('a[download]');
        if (!link || !window.goatcounter || !window.goatcounter.count) return;
        var href = link.getAttribute('href') || '';
        window.goatcounter.count({
          path: 'download-' + href.split('/').pop(),
          title: 'Download: ' + href,
          event: true,
        });
      });
    </script>
  </head>
  <body>
    <nav>
      <a href="/" class="brand">Yuri Tobias</a>
      <div class="nav-links">
        <a href="/" class:list={[{ active: pathname === '/' }]}>Sobre</a>
        <a href="/materiais" class:list={[{ active: pathname.startsWith('/materiais') }]}>Materiais</a>
        <a href="/ferramentas" class:list={[{ active: pathname.startsWith('/ferramentas') }]}>Ferramentas</a>
        <a href="/cursos" class:list={[{ active: pathname.startsWith('/cursos') }]}>Cursos</a>
        <a href="/blog" class:list={[{ active: pathname.startsWith('/blog') }]}>Blog</a>
      </div>
    </nav>
    <slot />
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  body { min-height: 100dvh; }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--rule);
  }

  .brand {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
  }

  .nav-links { display: flex; gap: 2rem; }

  .nav-links a {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .nav-links a:hover,
  .nav-links a.active { color: var(--accent); }
  .nav-links a.active { font-weight: 500; }

  @media (max-width: 640px) {
    nav {
      flex-direction: column;
      gap: 0.85rem;
      padding: 1rem 1.25rem;
    }
    .nav-links {
      gap: 1.1rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .nav-links a { font-size: 0.8rem; }
  }
</style>