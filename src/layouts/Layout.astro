---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  /** Caminho da imagem Open Graph (1200x630); o padrão é a imagem do site. */
  ogImage?: string;
  /** Tipo Open Graph: "website" (padrão) ou "article" para posts. */
  ogType?: 'website' | 'article';
  /** Dados estruturados (JSON-LD, schema.org) da página — objeto ou lista de objetos. */
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Analista de dados educacionais e professor de matemática em Poços de Caldas.",
  ogImage = '/og.png',
  ogType = 'website',
  schema,
} = Astro.props;
const pathname = Astro.url.pathname;
const tituloCompleto = title === 'Sobre' ? 'Yuri Tobias' : `${title} · Yuri Tobias`;
const canonical = new URL(pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site);
const ogImageAlt = ogImage === '/og.png'
  ? 'Yuri Tobias — Professor de Matemática e Analista de Dados Educacionais'
  : tituloCompleto;
const ano = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{tituloCompleto}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Yuri Tobias" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={tituloCompleto} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#1B4F4F" />
    <link rel="alternate" type="application/rss+xml" title="Blog · Yuri Tobias" href="/rss.xml" />
    {schema && <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />}
    <link rel="preload" href="/fonts/ibm-plex-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/playfair-display-latin.woff2" as="font" type="font/woff2" crossorigin />
    <script is:inline data-goatcounter="https://yuritobias.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
    <script is:inline>
      // Registra downloads de PDF como eventos no GoatCounter
      document.addEventListener('click', function (e) {
        var link = e.target.closest && e.target.closest('a[download]');
        if (!link || !window.goatcounter || !window.goatcounter.count) return;
        var href = link.getAttribute('href') || '';
        window.goatcounter.count({
          path: 'download-' + href.split('/').pop(),
          title: 'Download: ' + href,
          event: true,
        });
      });
    </script>
    <script is:inline>
      // Service worker: ferramentas e páginas visitadas funcionam offline.
      // Fora do localhost para não servir módulos velhos durante o desenvolvimento.
      if ('serviceWorker' in navigator && location.hostname !== 'localhost') {
        window.addEventListener('load', function () {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>
  </head>
  <body>
    <nav>
      <a href="/" class="brand">Yuri Tobias</a>
      <div class="nav-links">
        <a href="/" class:list={[{ active: pathname === '/' }]}>Sobre</a>
        <a href="/materiais" class:list={[{ active: pathname.startsWith('/materiais') }]}>Materiais</a>
        <a href="/ferramentas" class:list={[{ active: pathname.startsWith('/ferramentas') }]}>Ferramentas</a>
        <a href="/cursos" class:list={[{ active: pathname.startsWith('/cursos') }]}>Cursos</a>
        <a href="/blog" class:list={[{ active: pathname.startsWith('/blog') }]}>Blog</a>
      </div>
    </nav>
    <slot />
    <footer>
      <p class="licenca">
        Salvo indicação em contrário, os materiais didáticos e textos deste site estão sob a licença
        <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.pt-br" target="_blank" rel="license noopener">CC BY-NC-SA 4.0</a>
        — use e adapte livremente em sala de aula, com atribuição e sem fins comerciais.
      </p>
      <p class="footer-links">
        <span>© {ano} Yuri Tobias</span>
        <a href="mailto:yuritobias@gmail.com">E-mail</a>
        <a href="/rss.xml">RSS</a>
        <a href="https://github.com/yuritobias-cell/yuritobias.com" target="_blank" rel="noopener">Código-fonte</a>
      </p>
    </footer>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  body { min-height: 100dvh; display: flex; flex-direction: column; }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2rem;
    border-bottom: 1px solid var(--rule);
  }

  .brand {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink);
    text-decoration: none;
  }

  .nav-links { display: flex; gap: 2rem; }

  .nav-links a {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .nav-links a:hover,
  .nav-links a.active { color: var(--accent); }
  .nav-links a.active { font-weight: 500; }

  @media (max-width: 640px) {
    nav {
      flex-direction: column;
      gap: 0.85rem;
      padding: 1rem 1.25rem;
    }
    .nav-links {
      gap: 1.1rem;
      flex-wrap: wrap;
      justify-content: center;
    }
    .nav-links a { font-size: 0.8rem; }
  }

  footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem 2rem 2rem;
    border-top: 1px solid var(--rule);
    font-size: 0.8rem;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.6;
  }

  footer a {
    color: var(--accent);
    text-decoration: none;
  }

  footer a:hover { text-decoration: underline; }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.5rem;
  }

  @media (max-width: 640px) {
    footer { padding: 1.25rem 1.25rem 1.75rem; }
  }
</style>