---
import { slugTag } from '../utils/tags';

interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;
---

{tags.length > 0 && (
  <ul class="flex flex-wrap gap-2 list-none" aria-label="Tags">
    {tags.map(tag => (
      <li>
        <a
          href={`/blog/tag/${slugTag(tag)}`}
          class="inline-block text-xs px-2.5 py-0.5 rounded-full border border-stone-300 text-stone-500 hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition-colors"
        >
          {tag}
        </a>
      </li>
    ))}
  </ul>
)}
